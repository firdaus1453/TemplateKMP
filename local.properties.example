# Project-specific configuration
# Copy this file to local.properties and fill in the values

# Android SDK location (auto-detected by Android Studio, but required for CLI builds)
# sdk.dir=/path/to/Android/Sdk

# API Configuration
API_BASE_URL=https://dummyjson.com

# Firebase (optional — add when you integrate FCM push notifications)
# FIREBASE_PROJECT_ID=your-project-id
